getPopularSeries:
SELECT seriesEntry.id, COUNT(*) AS count
FROM artistSeriesConnection
JOIN seriesEntry ON artistSeriesConnection.seriesRowId = seriesEntry.rowid
WHERE (artistSeriesConnection.yearFlags & :flags) != 0
GROUP BY seriesEntry.id
ORDER BY count DESC
LIMIT 10;

getPopularMerch:
SELECT merchId, COUNT(*) AS count
FROM artistMerchConnection
WHERE (yearFlags & :flags) != 0
GROUP BY merchId
ORDER BY count DESC
LIMIT 10;
