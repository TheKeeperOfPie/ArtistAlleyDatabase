updateSeriesTagCounts:
UPDATE seriesEntry SET
inferred2024 = :inferredAnimeExpo2024,
inferred2025 = :inferredAnimeExpo2025,
inferredAnimeExpo2026 = :inferredAnimeExpo2026,
inferredAnimeNyc2024 = :inferredAnimeNyc2024,
inferredAnimeNyc2025 = :inferredAnimeNyc2025,
confirmed2024 = :confirmedAnimeExpo2024,
confirmed2025 = :confirmedAnimeExpo2025,
confirmedAnimeExpo2026 = :confirmedAnimeExpo2026,
confirmedAnimeNyc2024 = :confirmedAnimeNyc2024,
confirmedAnimeNyc2025 = :confirmedAnimeNyc2025
WHERE id = :id;

updateMerchYearFlags:
UPDATE merchEntry SET yearFlags = :yearFlags WHERE name = :id;

cleanUpForRelease {
    UPDATE artistEntryAnimeExpo2026 SET editorNotes = NULL;
    UPDATE artistEntryAnimeExpo2026 SET lastEditor = NULL;
    UPDATE seriesEntry SET synonyms = NULL;
}
