updateStampRallyAnimeExpo2024Images:
UPDATE stampRallyEntry2024 SET images = :images WHERE id = :id;

updateStampRallyAnimeExpo2025Images:
UPDATE stampRallyEntry2025 SET images = :images WHERE id = :id;

