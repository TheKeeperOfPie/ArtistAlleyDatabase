insertSeriesConnection:
INSERT OR REPLACE INTO artistSeriesConnection
VALUES ?;

insertMerchConnection:
INSERT OR REPLACE INTO artistMerchConnection
VALUES ?;

getSeries:
SELECT * FROM seriesEntry;

insertArtistConnection:
INSERT OR REPLACE INTO stampRallyArtistConnection
VALUES ?;

insertStampRallySeriesConnection:
INSERT OR REPLACE INTO stampRallySeriesConnection
VALUES ?;

insertArtistEntryAnimeExpo2026Changelog:
INSERT OR REPLACE INTO artistEntryAnimeExpo2026Changelog
VALUES ?;

updateArtistEntryAnimeExpo2023Images:
UPDATE artistEntry2023 SET images = :images WHERE id = :id;

updateArtistEntryAnimeExpo2024Images:
UPDATE artistEntry2024 SET images = :images WHERE id = :id;

updateArtistEntryAnimeExpo2025Images:
UPDATE artistEntry2025 SET images = :images WHERE id = :id;

